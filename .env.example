# Botfather'dan olingan token
BOT_TOKEN=123456:ABC-your-bot-token-here

# Botingizning username'i, @ belgisisiz (referal havolalar uchun kerak)
BOT_USERNAME=your_bot_username

# Majburiy obuna kanal(lar)i. Bir nechta bo'lsa vergul bilan ajratib yozing.
# MUHIM: bot bu kanal(lar)da ADMIN sifatida qo'shilgan bo'lishi shart,
# aks holda obunani tekshirish (getChatMember) ishlamaydi.
REQUIRED_CHANNELS=@your_channel

# Admin(lar)ning Telegram ID raqami (username emas, ID!). Bir nechta bo'lsa vergul bilan.
# O'z ID'ingizni bilish uchun Telegram'da @userinfobot ga /start yozing.
ADMIN_IDS=123456789

# To'lov qabul qilinadigan karta ma'lumotlari (foydalanuvchilarga shu ko'rsatiladi)
CARD_NUMBER=0000 0000 0000 0000
CARD_OWNER=F. ISM
